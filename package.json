{
  "type": "module",
  "dependencies": {
    "cheerio": "^1.0.0",
    "cloakbrowser": "^0.3.31",
    "dotenv": "^17.4.2",
    "duckduckgo-search": "^1.0.7",
    "ignore": "^7.0.0",
    "openai": "^6.35.0",
    "playwright-core": "^1.60.0",
    "tiktoken": "^1.0.20",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "test": "vitest run",
    "test:reliability": "vitest run --dir test/reliability",
    "test:functionality": "vitest run --dir test/functionality",
    "test:unit": "vitest run --grep-invert '@network'",
    "test:network": "vitest run --grep '@network'",
    "test:watch": "vitest"
  },
  "vitest": {
    "setupFiles": [
      "./test/setup.js"
    ],
    "test": {
      "globals": false
    }
  }
}
